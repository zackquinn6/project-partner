# Copy to .env and fill in (never commit .env).
# Supabase: Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key only — never put service_role or other secrets here.
VITE_SUPABASE_ANON_KEY=

# If your tooling uses this name instead of VITE_SUPABASE_ANON_KEY, set one or the other.
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: absolute URL for email confirmation after sign-up (defaults to {current origin}/auth)
# VITE_AUTH_EMAIL_REDIRECT_URL=https://your-production-domain.com/auth
